# Atlas DB
ATLAS_HOST=
ATLAS_PORT=5432
ATLAS_USER=
ATLAS_PASSWORD=
ATLAS_DB=

# --- API keys (only needed for the providers you use) ---
GOOGLE_API_KEY=         # required if using google/ models
ANTHROPIC_API_KEY=      # required if using anthropic/ models
COHERE_API_KEY=         # required if using cohere/ models

# Hugging Face (for S-BERT model downloads)
HF_TOKEN=

# --- Models ---
# Format: "provider/model-name" — uses instructor.from_provider()
# Examples:
#   google/gemini-2.5-flash-lite, google/gemini-2.0-flash
#   anthropic/claude-3-haiku-20240307, anthropic/claude-sonnet-4-20250514
#   cohere/command-r-plus
EMBEDDING_MODEL=dell-research-harvard/lt-un-data-fine-fine-en
SEARCH_TERM_MODEL=google/gemini-2.5-flash-lite
RERANKER_MODEL=google/gemini-2.5-flash-lite

# --- LLM ---
# Temperature for search term generation and reranking (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# --- Retrieval ---
# TOP_K_TOTAL: total FAISS candidates retrieved across all searches (~25 is a good default)
# TOP_K_BERT:  how many of those go to the original query; the rest are split across search terms
# Higher TOP_K_TOTAL = more candidates for the reranker (better recall, costlier reranking)
# Higher TOP_K_BERT  = more weight on the raw query vs LLM-generated search terms
TOP_K_TOTAL=25
TOP_K_BERT=10
